{
  "package_id": "com.example.evenaudiopipe",
  "edition": "202601",
  "name": "Agent Audio Pipe",
  "version": "0.1.18",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.10",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "g2-microphone",
      "desc": "Capture audio from the G2 microphone."
    },
    {
      "name": "network",
      "desc": "Stream microphone PCM audio to your local receiver.",
      "whitelist": [
        "ws://192.168.1.100:8788",
        "ws://192.168.1.100:8788/audio",
        "http://192.168.1.100:8788",
        "wss://192.168.1.100:8788",
        "wss://192.168.1.100:8788/audio",
        "https://192.168.1.100:8788"
      ]
    }
  ],
  "supported_languages": [
    "en"
  ]
}
