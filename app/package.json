{
  "name": "agent-audio-pipe-app",
  "private": true,
  "version": "0.1.18",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pack": "evenhub pack app.json dist -o even-audio-pipe-$npm_package_version.ehpk",
    "test:endpoints": "tsx test/audioEndpoints.test.ts",
    "test:bundle-urls": "node test/bundleUrls.test.mjs",
    "test:speech-dispatch": "tsx test/speechDispatchDisplay.test.ts",
    "test:memory": "tsx test/memoryBounds.test.ts",
    "test:startup-prompt": "tsx test/startupPrompt.test.ts",
    "test:history": "tsx test/historyCanvas.test.ts && tsx test/historyNavigator.test.ts",
    "test:history:current": "tsx test/historyCurrentData.test.ts",
    "simulate": "evenhub-simulator http://localhost:5173"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "@evenrealities/pretext": "^0.1.4"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.12",
    "@evenrealities/evenhub-simulator": "^0.7.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  }
}
